# Git attributes for SoundReminder
# Ensures consistent line endings across platforms

* text=auto eol=lf

# Java source files use LF
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf

# Config files use LF
*.xml text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Scripts use LF
*.sh text eol=lf
*.py text eol=lf

# Markdown uses LF
*.md text eol=lf

# Windows batch files use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.wav binary
*.mp3 binary
*.jar binary
*.zip binary

# Ignore generated build artifacts
build/ binary
.gradle/ binary

# IDE files (if accidentally committed)
.idea/ binary
*.iml binary
